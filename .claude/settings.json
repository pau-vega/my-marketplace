{
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-pnpm.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/no-package-json-edit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/no-enum.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/no-export-default.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/no-any.sh"
          }
        ]
      }
    ]
  }
}
